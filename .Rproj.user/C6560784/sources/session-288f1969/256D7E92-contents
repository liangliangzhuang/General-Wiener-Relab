t_vector <- c(0, 10, 15, 20, 25, 30, 35, 40)
jags_data <- load_jags_data_from_csv(csv_file_path, t_vector)
# 设置失效阈值 (PC1, PC2) - 请根据实际情况修改
thresholds <- c(4, 7)
# ==============================================================================
# 2. 定义初始值配置
# ==============================================================================
# --- A. General Model Inits ---
inits_general_power <- list(
  eta_mean = 25, eta_sd = 1, mu0 = 25, invSIG0_scale = 1,
  true_scale = c(1, 1), tau_scale = c(1, 1), invcsi = c(1, 100)
)
inits_general_exp <- list(
  eta_mean = 0.5, eta_sd = 0.1, mu0 = 0.5, invSIG0_scale = 0.1,
  true_scale = c(0.05, 0.05), tau_scale = c(1, 1), invcsi = c(40000, 40000)
)
# --- B. Wiener Model Inits ---
inits_wiener <- list(
  mu0 = 0.6, sigma2_err = 0.1, Tau_b_scale = 1, b_val = 0.6, scale = c(1, 1.5)
)
# --- C. Student Model Inits (从 student unlinear.R 提取) ---
inits_student <- list(
  eta = c(0.03, 0.03),        # 原始代码 0.03*c(1,1)
  SIG0_inv_scale = 1,
  scale = c(1, 1),
  sig_w = c(1, 1)
)

# ==============================================================================
# 3. 批量运行配置
# ==============================================================================

scenarios <- data.frame(
  Model_Name = c(
    "General PP", "General PE", "General EP", "General EE", 
    "Wiener PP", "Wiener EE",
    "Student PP", "Student EE"  # 新增
  ),
  Class = c(
    "General", "General", "General", "General",
    "Wiener", "Wiener",
    "Student", "Student"
  ),
  Drift_Type = c(
    "Power", "Power", "Exponential", "Exponential",
    "Power", "Exponential",
    "Power", "Exponential"
  ),
  Diff_Type = c( # 仅 General 需要此列区分
    "Power", "Exponential", "Power", "Exponential",
    NA, NA, NA, NA
  ),
  stringsAsFactors = FALSE
)

final_results_list <- list()

for (i in 1:nrow(scenarios)) {
  model_name <- scenarios$Model_Name[i]
  model_class <- scenarios$Class[i]
  d_type     <- scenarios$Drift_Type[i]
  diff_type  <- scenarios$Diff_Type[i]
  
  message(paste0("\n--------------------------------------------------------"))
  message(paste0("Running [", i, "/8]: ", model_name))
  message(paste0("--------------------------------------------------------"))
  
  # --- A. 运行 MCMC ---
  if (model_class == "General") {
    # >>> General Models <<<
    curr_inits <- if(d_type == "Power") inits_general_power else inits_general_exp
    if(model_name == "General EP") curr_inits$tau_scale <- 1
    
    res <- run_inference(jags_data, d_type, diff_type, curr_inits, 
                         n.chains=2, n.adapt=1000, n.iter=5000)
    
    stats <- summary(res$samples)$statistics[, "Mean"]
    dic_val <- sum(res$dic$deviance) + sum(res$dic$penalty)
    
    # 映射 (General 模型有 mu0)
    mu_1 <- stats["mu0[1]"]; mu_2 <- stats["mu0[2]"]
    r_1 <- stats["true_scale[1]"]; r_2 <- stats["true_scale[2]"]
    s_1 <- stats["tau_scale[1]"];  s_2 <- stats["tau_scale[2]"]
    xi_1 <- stats["csi[1]"]; xi_2 <- stats["csi[2]"]
    
  } else if (model_class == "Wiener") {
    # >>> Wiener Models <<<
    res <- run_wiener_inference(jags_data, d_type, inits_wiener, 
                                n.chains=2, n.adapt=1000, n.iter=5000)
    
    stats <- summary(res$samples)$statistics[, "Mean"]
    dic_val <- sum(res$dic$deviance) + sum(res$dic$penalty)
    
    # 映射 (Wiener 模型 mu0 代表 drift mean)
    mu_1 <- stats["mu0[1]"]; mu_2 <- stats["mu0[2]"]
    # Wiener 只有一个 scale，同时作为 r 和 s
    r_1 <- stats["scale[1]"]; r_2 <- stats["scale[2]"]
    s_1 <- r_1; s_2 <- r_2
    xi_1 <- stats["sigma2_err[1]"]; xi_2 <- stats["sigma2_err[2]"]
    
  } else {
    # >>> Student Models <<<
    res <- run_student_inference(jags_data, d_type, inits_student, 
                                 n.chains=2, n.adapt=1000, n.iter=5000)
    
    stats <- summary(res$samples)$statistics[, "Mean"]
    dic_val <- sum(res$dic$deviance) + sum(res$dic$penalty)
    
    # 映射 (Student 模型 eta 代表 drift mean)
    mu_1 <- stats["eta[1]"]; mu_2 <- stats["eta[2]"]
    # Student 只有一个 scale
    r_1 <- stats["scale[1]"]; r_2 <- stats["scale[2]"]
    s_1 <- r_1; s_2 <- r_2
    xi_1 <- stats["sig.w[1]"]; xi_2 <- stats["sig.w[2]"]
  }
  
  # --- B. 保存诊断图 ---
  save_diagnostics(res$samples, model_name, output_dir = current_case_folder)

  
  # --- 整理当前行数据 ---
  # 注意：Student 和 Wiener 的 sigma/rho 都是随机效应的协方差参数
  row_data <- data.frame(
    Model   = model_name,
    mu_1    = mu_1,
    mu_2    = mu_2,
    sigma_1 = stats["sigma[1]"],
    sigma_2 = stats["sigma[2]"],
    rho_12  = stats["rho[1,2]"],
    r_1     = r_1,
    r_2     = r_2,
    s_1     = s_1,
    s_2     = s_2,
    xi_1    = xi_1,  
    xi_2    = xi_2, 
    DIC     = dic_val,
    stringsAsFactors = FALSE
  )
  
  final_results_list[[i]] <- row_data
}

# ==============================================================================
# 5. 汇总输出
# ==============================================================================
